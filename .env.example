# AI Studio Applet Configuration
# .env.example

# Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# Firebase Configuration (Automatically populated during setup)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# GA4 S2S Tracking (Measurement Protocol)
# Get these from GA4 Admin > Data Streams > [Your Stream] > Measurement Protocol API secrets
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
